# =============================================================================
# LinkOps — Environment Variables (Docker Compose + Backend)
# =============================================================================
# Copy this file to .env in the project root.
# These variables are shared by Docker Compose services and the backend app.
# =============================================================================

# --- PostgreSQL ---------------------------------------------------------------
POSTGRES_USER=linkops
POSTGRES_PASSWORD=linkops
POSTGRES_DB=linkops
POSTGRES_PORT=5432

# Backend connection string (points to Docker service hostname for compose,
# use localhost when running the backend on the host machine).
DATABASE_URL=postgresql+psycopg://linkops:linkops@localhost:5432/linkops

# --- Redis --------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# --- Neo4j --------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=linkops_neo4j
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# --- MinIO (S3-compatible object storage) ------------------------------------
MINIO_ROOT_USER=linkops
MINIO_ROOT_PASSWORD=linkops123
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=linkops
MINIO_SECRET_KEY=linkops123
MINIO_SECURE=false
MINIO_BUCKET=documents
MINIO_BUCKETS=documents,thumbnails,exports,future-models
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- pgAdmin (optional — only with `docker compose --profile tools up`) ------
PGADMIN_DEFAULT_EMAIL=admin@linkops.local
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_PORT=5050

# --- Application --------------------------------------------------------------
APP_ENV=local
APP_DEBUG=false
APP_NAME=LinkOps API
APP_VERSION=1.0.0
LOG_LEVEL=INFO

# --- AI (optional) ------------------------------------------------------------
OPENAI_API_KEY=
SUPABASE_URL=
SUPABASE_KEY=
