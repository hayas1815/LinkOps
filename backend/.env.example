# LinkOps Backend — Environment Variables
# Copy this file to .env and fill in the values for your environment.

# Application
APP_ENV=local
APP_DEBUG=false
APP_NAME=LinkOps API
APP_VERSION=1.0.0
LOG_LEVEL=INFO

# PostgreSQL (asyncpg driver — use postgresql:// or postgresql+psycopg:// format)
DATABASE_URL=postgresql+asyncpg://linkops:linkops@localhost:5432/linkops

# PostgreSQL connection pool tuning
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=linkops_neo4j

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO / S3-compatible object storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=linkops
MINIO_SECRET_KEY=linkops123
MINIO_SECURE=false

# AI (optional — set when integrating AI providers)
OPENAI_API_KEY=
SUPABASE_URL=
SUPABASE_KEY=
